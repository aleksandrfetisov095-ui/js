function rand(min,max){
    return Math.floor(Math.random() * (max - min + 1)) + min;
}
let myNumbers = [5, 7, 3, 1, 2];
function unik(mass) {
    let newname;
    do {
        newname = rand(1,10);
    } while (mass.includes(newname));
    mass.push(newname);
    return mass
}

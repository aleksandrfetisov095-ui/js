function Spam(text) {
    let lowerText = text.toLowerCase();

    const spamWords = [
        "100%",
        "бесплатно",
        "увеличение продаж",
        "только сегодня",
        "не удаляйте"
    ];

    for (let word of spamWords) {
        if (lowerText.includes(word.toLowerCase())) {
            return true; 
        }
    }

    return false;
}
console.log(Spam("Купите сейчас! Только сегодня скидка 100%!"));
console.log(Spam("Просто хорошее предложение")); 

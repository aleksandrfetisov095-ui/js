function longestWord(slov) {
    let words = slov.split(" ");

    let longest = "";

    for (let word of words) {
        let cleanWord = word.replace(/[.,!?;:'"]/g, "");

        if (cleanWord.length > longest.length) {
            longest = cleanWord;
        }
    }

    return longest;
}

console.log(longestWord("Hello world"));    
console.log(longestWord("JavaScript language"));


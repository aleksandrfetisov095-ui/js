// задание 30
function meanScore(...numbers) {
    if (numbers.length === 0) {
        return 0;
    }

    let sum = 0;
    for (let num of numbers) {
        sum += num;
    }

    let average = sum / numbers.length;
    return parseFloat(average);
}

console.log(meanScore(10, 20, 30));
console.log(meanScore(5, 15, 25));
console.log(meanScore()); 

// задание 33
function createFraction(numerator, denominator) {
    return {
        numerator: numerator,
        denominator: denominator
    };
}

function addFractions(frac1, frac2) {
    let num = frac1.numerator * frac2.denominator + frac2.numerator * frac1.denominator;
    let den = frac1.denominator * frac2.denominator;
    return createFraction(num, den);
}

function subtractFractions(frac1, frac2) {
    let num = frac1.numerator * frac2.denominator - frac2.numerator * frac1.denominator;
    let den = frac1.denominator * frac2.denominator;
    return createFraction(num, den);
}

function multiplyFractions(frac1, frac2) {
    let num = frac1.numerator * frac2.numerator;
    let den = frac1.denominator * frac2.denominator;
    return createFraction(num, den);
}

function divideFractions(frac1, frac2) {
    let num = frac1.numerator * frac2.denominator;
    let den = frac1.denominator * frac2.numerator;
    return createFraction(num, den);
}

function printFraction(frac) {
    console.log(`${frac.numerator} / ${frac.denominator}`);
}

let f1 = createFraction(1, 2);   
let f2 = createFraction(1, 3);   

printFraction(addFractions(f1, f2));      
printFraction(subtractFractions(f1, f2)); 
printFraction(multiplyFractions(f1, f2)); 
printFraction(divideFractions(f1, f2));   

// задание 36

function truncateString(str, maxLength) {
    if (str.length <= maxLength) {
        return str;
    } else {
        return str.slice(0, maxLength) + "..."; 
    }
}

console.log(truncateString("Hello, world!", 5));  
console.log(truncateString("Hi", 10));             
console.log(truncateString("just remember", 10));



